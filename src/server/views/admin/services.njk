{% from "govuk/components/button/macro.njk" import govukButton %}

{% extends "../layout.njk" %}

{% block content %}
<h1 class="govuk-heading-xl">Services</h1>

{{ govukButton({
  text: "Register new service",
  href: "/admin/services/new"
}) }}

<table class="govuk-table">
  <thead class="govuk-table__head">
    <tr class="govuk-table__row">
      <th scope="col" class="govuk-table__header">Name</th>
      <th scope="col" class="govuk-table__header">Organisation</th>
      <th scope="col" class="govuk-table__header">Created</th>
      <th scope="col" class="govuk-table__header">Actions</th>
      <th scope="col" class="govuk-table__header"></th>
    </tr>
  </thead>
  <tbody class="govuk-table__body">
    {% for service in services %}
    <tr class="govuk-table__row">
      <td class="govuk-table__cell"><a href="/services/{{ service.id }}" class="govuk-link">{{ service.name }}</a></td>
      <td class="govuk-table__cell">{{ service.organisation }}</td>
      <td class="govuk-table__cell">{{ service.created_at | date }}</td>
      <td class="govuk-table__cell">
        <a href="/admin/services/{{ service.id }}/keys" class="govuk-link">Keys</a> |
        <a href="/admin/services/{{ service.id }}/edit" class="govuk-link">Edit</a> |
        <a href="/admin/services/{{ service.id }}/onboard" class="govuk-link">Onboard</a>
      </td>
      <td class="govuk-table__cell">
        <form method="POST" action="/admin/services/{{ service.id }}/delete" class="js-delete-form" style="margin: 0;">
          {{ govukButton({
            text: "Delete",
            classes: "govuk-button--warning govuk-!-margin-bottom-0"
          }) }}
        </form>
      </td>
    </tr>
    {% else %}
    <tr class="govuk-table__row">
      <td class="govuk-table__cell" colspan="5">No services registered.</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<script nonce="{{ cspNonce }}">
  document.querySelectorAll('.js-delete-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      if (!confirm('Delete this service? This removes all SBOMs, keys, and vulnerabilities.')) {
        e.preventDefault();
      }
    });
  });
</script>
{% endblock %}
