{
  "name": "sbom-service",
  "version": "0.1.0",
  "description": "SBOM ingestion, vulnerability scanning, and release cadence tracking for VODG",
  "main": "dist/main.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/main.ts",
    "dev:watch": "nodemon --watch src --ext ts,njk --exec 'ts-node src/main.ts'",
    "start": "node dist/main.js",
    "lint": "eslint . --fix && prettier --write '**/*.ts'",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "playwright test",
    "db:migrate": "ts-node src/db/migrate.ts",
    "generate-key": "ts-node scripts/generate-api-key.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "ae-cvss-calculator": "^1.0.12",
    "connect-pg-simple": "^10.0.0",
    "csrf-sync": "^4.2.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.0.0",
    "nunjucks": "^3.2.4",
    "openid-client": "^6.3.3",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "semver": "^7.7.4",
    "unzipper": "^0.12.3",
    "uuid": "^11.0.5",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/jest": "^30.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/pg": "^8.11.11",
    "@types/semver": "^7.7.1",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
